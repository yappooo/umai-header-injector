{
  "manifest_version": 3,
  "name": "UMAI Venue API Header Injector",
  "version": "1.4.0",
  "description": "Injects a venue-api-key header into UMAI reservation widget requests to bypass venue-gated API checks, without touching Stripe traffic.",
  "permissions": ["declarativeNetRequest", "storage", "webRequest", "tabs", "scripting", "notifications"],
  "host_permissions": [
    "https://*.umai.io/*",
    "https://*.letsumai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UMAI Header Injector"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
